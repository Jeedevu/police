# ── KSP Crime Intelligence Platform — Railway Environment Variables ──────────
# Copy these to Railway Dashboard → Variables
# Railway auto-provides DATABASE_URL when you add a PostgreSQL plugin

# ── Database (Railway provides this automatically) ────────────────────────────
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── JWT Security — CHANGE THESE ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=replace_with_random_64_char_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS — your Vercel frontend URL ───────────────────────────────────────────
# Add your Vercel deployment URL here (comma-separated, no spaces)
EXTRA_CORS_ORIGINS=https://your-project.vercel.app

# ── Zoho Catalyst (optional / legacy) ─────────────────────────────────────────
CATALYST_URL=
CATALYST_TOKEN=
CATALYST_ORG=
